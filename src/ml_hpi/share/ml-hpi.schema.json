{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/fvutils/ml-hpi/schema/ml-hpi.schema.json",
  "title": "ml-hpi Interface Definition",
  "description": "Schema for the Multi-Language Hierarchical Programming Interface (ml-hpi)",
  "type": "object",
  "required": ["ml-hpi"],
  "additionalProperties": false,
  "properties": {
    "ml-hpi": {
      "type": "object",
      "required": ["interfaces"],
      "additionalProperties": false,
      "properties": {
        "interfaces": {
          "type": "array",
          "items": { "$ref": "#/$defs/interface" }
        }
      }
    }
  },

  "$defs": {

    "param_type": {
      "description": "Scalar types valid for method parameters and return values (excluding void)",
      "type": "string",
      "enum": [
        "bool",
        "int8",   "uint8",
        "int16",  "uint16",
        "int32",  "uint32",
        "int64",  "uint64",
        "addr",   "addr32", "addr64",
        "uintptr"
      ]
    },

    "rtype": {
      "description": "Scalar types valid for method return values (includes void)",
      "type": "string",
      "enum": [
        "void",
        "bool",
        "int8",   "uint8",
        "int16",  "uint16",
        "int32",  "uint32",
        "int64",  "uint64",
        "addr",   "addr32", "addr64",
        "uintptr"
      ]
    },

    "iface_type_ref": {
      "description": "Qualified interface type name, e.g. pkg.MyIf1",
      "type": "string",
      "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*(\\.[a-zA-Z_][a-zA-Z0-9_]*)*$"
    },

    "param": {
      "description": "A method parameter",
      "type": "object",
      "required": ["name", "type"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
        },
        "type": { "$ref": "#/$defs/param_type" }
      }
    },

    "method_attr": {
      "description": "A single method attribute key-value pair",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "solve":    { "type": "boolean", "description": "PSS: callable during solve phase" },
        "target":   { "type": "boolean", "description": "PSS: callable during target phase" },
        "blocking": { "type": "boolean", "description": "SystemVerilog: true=task (blocking), false=function (non-blocking)" }
      }
    },

    "method": {
      "description": "An interface method",
      "type": "object",
      "required": ["name", "rtype"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
        },
        "rtype": { "$ref": "#/$defs/rtype" },
        "params": {
          "type": "array",
          "items": { "$ref": "#/$defs/param" }
        },
        "attr": {
          "description": "List of method attribute objects (one key per item)",
          "type": "array",
          "items": { "$ref": "#/$defs/method_attr" }
        }
      }
    },

    "member": {
      "description": "A sub-interface field or array member",
      "type": "object",
      "required": ["name", "kind", "type"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$"
        },
        "kind": {
          "type": "string",
          "enum": ["field", "array"],
          "description": "'field' = single sub-interface; 'array' = indexed collection of sub-interfaces"
        },
        "type": { "$ref": "#/$defs/iface_type_ref" }
      }
    },

    "interface": {
      "description": "A named interface type with methods and/or sub-interface members",
      "type": "object",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "$ref": "#/$defs/iface_type_ref" },
        "extends": {
          "description": "Optional single base interface this interface inherits from",
          "$ref": "#/$defs/iface_type_ref"
        },
        "methods": {
          "type": "array",
          "items": { "$ref": "#/$defs/method" }
        },
        "members": {
          "type": "array",
          "items": { "$ref": "#/$defs/member" }
        }
      }
    }

  }
}
